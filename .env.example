# Configure a conta de envio de e-mail para a verificação real.
# Você deve criar um arquivo .env local e preencher estes valores.

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu-email@example.com
EMAIL_PASS=sua-senha-ou-app-password
EMAIL_FROM="Meu financeiro" <no-reply@seu-dominio.com>
PORT=3000
